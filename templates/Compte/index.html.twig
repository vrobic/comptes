{% extends 'layout.html.twig' %}

{% block modules 'highcharts' %}

{% block title %} - Comptes{% endblock %}

{% block content %}
    <h1>Comptes</h1>
    <div class="row">
        {% for compte in comptes.ouverts %}
            <div class="widget col-md-3">
                <a href="{{ path('comptes_compte', {'compteId': compte.id}) }}">
                    <div class="widget-content">
                        <div class="widget-icon pull-left">
                            <span class="glyphicon glyphicon-euro"></span>
                        </div>
                        <h3>
                            {{ compte.solde < 0 ? "-" }} <strong>{{ compte.solde|abs|number_format(2, ",", " ") ~ " €" }}</strong>
                            <small>{{ compte }}</small>
                        </h3>
                    </div>
                </a>
            </div>
            {% if loop.index % 4 == 0 %}</div><div class="row">{% endif %}
        {% endfor %}
        {% if comptes.fermés is not empty %}
            <div class="widget col-md-12">
                <button class="btn btn-default" data-toggle="collapse" data-target=".collapse">
                    <span class="glyphicon glyphicon-eye-close"></span> Afficher les comptes fermés
                </button>
            </div>
        {% endif %}
    </div>
    {% if comptes.fermés is not empty %}
        <div class="row collapse">
            {% for compte in comptes.fermés %}
                <div class="widget col-md-3">
                    <a href="{{ path('comptes_compte', {'compteId': compte.id}) }}">
                        <div class="widget-content">
                            <div class="widget-icon pull-left">
                                <span class="glyphicon glyphicon-euro"></span>
                            </div>
                            <h3>
                                {{ compte.solde < 0 ? "-" }} <del>{{ compte.solde|abs|number_format(2, ",", " ") ~ " €" }}</del>
                                <small>{{ compte }}</small>
                            </h3>
                        </div>
                    </a>
                </div>
                {% if loop.index % 4 == 0 %}</div><div class="row collapse">{% endif %}
            {% endfor %}
        </div>
    {% endif %}
    <div class="row">
        <div id="chart-1" class="chart col-md-12"></div>
        <script>
            $(function(){
                $('#chart-1').highcharts({
                    chart: {
                        type: 'bar'
                    },
                    title: {
                        text: "Situation financière"
                    },
                    xAxis: {
                        categories: [
                            {% for compte in comptes %}
                                {% if compte.dateFermeture is null %}
                                    `<a href="{{ path('comptes_compte', {'compteId': compte.id})|e('js') }}">{{ compte|e('js') }}</a>`,
                                {% endif %}
                            {% endfor %}
                        ],
                        labels: {
                            useHTML: true
                        },
                        title: {
                            text: "Comptes"
                        }
                    },
                    yAxis: {
                        title: {
                            text: "Solde (€)",
                            align: 'high'
                        }
                    },
                    plotOptions: {
                        bar: {
                            cursor: 'pointer',
                            point: {
                                events: {
                                    click: function() {
                                        window.location.href = this.url;
                                    }
                                }
                            }
                        }
                    },
                    tooltip: {
                        valueSuffix: "€"
                    },
                    series: [{
                        name: "Solde",
                        data: [
                            {% for compte in comptes %}
                                {% if compte.dateFermeture is null %}
                                    {
                                        y: {{ compte.solde|e('js') }},
                                        url: "{{ path('comptes_compte', {'compteId': compte.id})|e('js') }}"
                                    },
                                {% endif %}
                            {% endfor %}
                        ],
                    }]
                });
            });
        </script>
    </div>
    <div class="row">
        <div id="chart-2" class="chart col-md-12"></div>
        <script>
            $(function(){
                $('#chart-2').highcharts({
                    chart: {
                        type: 'bar',
                        // marges empiriques mais suffisantes pour afficher...
                        marginLeft: 100, // ... le montant des histogrammes négatifs
                        marginRight: 100 // ... le montant des histogrammes positifs, ainsi que la légende
                    },
                    title: {
                        text: "Balance des derniers mois"
                    },
                    subtitle: {
                        text: "Moyenne mensuelle : {{ balance_moyenne_des_derniers_mois|number_format(2, ",", " ") ~ " €" }}{% if balance_moyenne_des_mois_positifs is not null %} ({{ balance_moyenne_des_mois_positifs|number_format(2, ",", " ") ~ " €" }} pour les mois positifs){% endif %}",
                        x: -20 // centrage
                    },
                    xAxis: {
                        categories: [
                            {% for mois, balance in balance_des_derniers_mois %}
                                "{{ mois|e('js') }}",
                            {% endfor %}
                        ],
                        labels: {
                            step: 1,
                        },
                    },
                    yAxis: {
                        title: {
                            text: "Balance (€)",
                            align: 'high'
                        }
                    },
                    plotOptions: {
                        bar: {
                            dataLabels: {
                                enabled: true,
                                crop: false,
                                overflow: "allow",
                                style: {
                                    fontSize: "20px",
                                    textShadow: "none",
                                    textOutline: "none",
                                    color: "#510477"
                                },
                                formatter: function() {
                                    return new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(this.y) + ' €';
                                }
                            }
                        }
                    },
                    tooltip: {
                        enabled: false
                    },
                    series: [{
                        name: "Balance",
                        data: [
                            {% for mois, balance in balance_des_derniers_mois %}
                                {
                                    y: {{ balance|e('js') }}
                                },
                            {% endfor %}
                        ],
                    }]
                });
            });
        </script>
    </div>
    <div class="row">
        <div id="chart-3" class="chart col-md-12"></div>
        <script>
            $(function(){
                $('#chart-3').highcharts({
                    chart: {
                        zoomType: 'x'
                    },
                    title: {
                        text: "Solde cumulé",
                        x: -20 // centrage
                    },
                    xAxis: {
                        type: 'datetime'
                    },
                    yAxis: {
                        title: {
                            text: "Solde cumulé (€)"
                        }
                    },
                    tooltip: {
                        valueSuffix: "€",
                        crosshairs: true
                    },
                    series: [{
                        name: "Solde cumulé",
                        data: [
                            {% set solde_total = 0 %}
                            {% for key, mouvement in mouvements %}
                                {% set solde_total = solde_total + mouvement.montant %}
                                {% if (first_mouvement.date <= mouvement.date and mouvement.date <= last_mouvement.date) and ((mouvements[key+1] is not defined) or (mouvements[key+1] is defined and mouvements[key+1].date != mouvement.date)) %}
                                    [
                                        Date.UTC({{ mouvement.date|date('Y')|e('js') }}, {{ (mouvement.date|date('m')-1)|e('js') }}, {{ mouvement.date|date('d')|e('js') }}),
                                        {{ solde_total|e('js') }}
                                    ],
                                {% endif %}
                            {% endfor %}
                        ]
                    }]
                });
            });
        </script>
    </div>
{% endblock %}
